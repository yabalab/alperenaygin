# Copy to .env.local and fill in real values (Supabase → Project Settings → API).
# .env.local is git-ignored; this .env.example is committed as documentation.

# Public (browser-safe; RLS-gated):
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Server ONLY — bypasses RLS. Never expose to the client / commit.
SUPABASE_SERVICE_ROLE_KEY=

# Cloudflare Turnstile (booking-form bot protection).
# Public site key (browser-safe):
NEXT_PUBLIC_TURNSTILE_SITE_KEY=
# Server ONLY — Turnstile secret (verifies tokens; never commit):
TURNSTILE_SECRET_KEY=
